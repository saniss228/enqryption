#:kivy 2.2.0
#:import dp kivy.metrics.dp

BoxLayout:
    orientation: "vertical"
    spacing: "12dp"
    padding: "16dp"
    canvas.before:
        Color:
            rgba: (0.01, 0.02, 0.05, 1)
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: (0.04, 0.07, 0.18, 1)
        Rectangle:
            pos: self.x, self.top - 100
            size: self.width, 100

    BoxLayout:
        size_hint_y: None
        height: "64dp"
        padding: "6dp"
        spacing: "10dp"

        Label:
            text: "Secure Messenger Desktop"
            font_size: "22sp"
            bold: True
            color: (1, 1, 1, 1)
            halign: "left"
            valign: "middle"
            text_size: self.size

        BoxLayout:
            size_hint_x: None
            width: "140dp"
            spacing: "8dp"

            Button:
                text: app.language_button_text
                size_hint_y: None
                height: "36dp"
                background_normal: ""
                background_color: (0.06, 0.08, 0.19, 1)
                color: (0.96, 0.96, 1, 1)
                on_release: app.toggle_language()

    Label:
        text: app.log_text
        size_hint_y: None
        height: "22dp"
        color: (0.8, 0.85, 1, 1)
        font_size: "13sp"
        halign: "right"
        valign: "middle"
        text_size: self.size

    ScreenManager:
        id: screens

        Screen:
            name: "login"
            AnchorLayout:
                anchor_x: "center"
                anchor_y: "center"

                BoxLayout:
                    orientation: "vertical"
                    size_hint: None, None
                    size: "440dp", "520dp"
                    padding: "30dp"
                    spacing: "16dp"
                    canvas.before:
                        Color:
                            rgba: (0.06, 0.08, 0.2, 0.95)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [30]
                        Color:
                            rgba: (0.12, 0.15, 0.25, 0.6)
                        Line:
                            width: 1.5
                            rounded_rectangle: (self.x + 10, self.y + 10, self.width - 20, self.height - 20, 28)

                    Label:
                        text: app.login_title
                        font_size: "26sp"
                        bold: True
                        color: (0.95, 0.95, 1, 1)
                        size_hint_y: None
                        height: "44dp"

                    TextInput:
                        id: nick_input
                        hint_text: app.nick_hint_text
                        multiline: False
                        background_normal: ""
                        background_active: ""
                        background_color: (0.08, 0.1, 0.18, 1)
                        foreground_color: (1, 1, 1, 1)
                        padding: [14, 14, 14, 14]
                        font_size: "16sp"

                    BoxLayout:
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: "8dp"

                        Label:
                            text: app.password_label
                            font_size: "16sp"
                            color: (0.85, 0.9, 1, 1)
                            halign: "left"
                            valign: "middle"
                            size_hint_x: 0.4
                            size_hint_y: None
                            height: self.texture_size[1]
                            text_size: (self.width, None)

                        Label:
                            text: app.password_hint_text
                            font_size: "12sp"
                            color: (0.55, 0.65, 0.9, 1)
                            halign: "right"
                            valign: "middle"
                            size_hint_x: 0.6
                            size_hint_y: None
                            height: max(self.texture_size[1], dp(26))
                            text_size: (self.width, None)

                    TextInput:
                        id: password_input
                        hint_text: app.password_label
                        password: True
                        multiline: False
                        background_normal: ""
                        background_active: ""
                        background_color: (0.08, 0.1, 0.18, 1)
                        foreground_color: (1, 1, 1, 1)
                        padding: [14, 14, 14, 14]
                        font_size: "16sp"

                    Label:
                        text: app.password_guidance
                        font_size: "12sp"
                        color: (1, 0.4, 0.4, 1)
                        size_hint_y: None
                        height: "20dp"
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    BoxLayout:
                        size_hint_y: None
                        height: "44dp"
                        spacing: "10dp"

                        Button:
                            text: app.login_button_text
                            background_normal: ""
                            background_color: (0.08, 0.12, 0.2, 1)
                            color: (0.95, 0.95, 1, 1)
                            on_release:
                                app.login(nick_input.text.strip(), password_input.text)

                        Button:
                            text: app.register_button_text
                            background_normal: ""
                            background_color: (0.08, 0.12, 0.2, 1)
                            color: (0.95, 0.95, 1, 1)
                            on_release:
                                app.register(nick_input.text.strip(), password_input.text)

                    Button:
                        text: app.language_button_text
                        size_hint_y: None
                        height: "36dp"
                        background_normal: ""
                        background_color: (0.06, 0.08, 0.19, 1)
                        color: (0.94, 0.94, 1, 1)
                        on_release: app.toggle_language()

        Screen:
            name: "chat"
            BoxLayout:
                orientation: "horizontal"
                spacing: "16dp"
                padding: "16dp"

                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.35
                    spacing: "12dp"
                    padding: "12dp"
                    canvas.before:
                        Color:
                            rgba: (0.06, 0.08, 0.18, 0.9)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [20]
                        Color:
                            rgba: (0.12, 0.15, 0.25, 0.8)
                        Line:
                            width: 1.2
                            rounded_rectangle: (self.x + 6, self.y + 6, self.width - 12, self.height - 12, 18)

                    Label:
                        text: app.friends_label
                        font_size: "18sp"
                        color: (0.9, 0.9, 1, 1)
                        bold: True
                        size_hint_y: None
                        height: "32dp"

                    ScrollView:
                        GridLayout:
                            id: friends_container
                            cols: 1
                            spacing: "8dp"
                            size_hint_y: None
                            height: self.minimum_height

                    Button:
                        text: app.fetch_pending_text
                        size_hint_y: None
                        height: "40dp"
                        background_normal: ""
                        background_color: (0.08, 0.12, 0.2, 1)
                        color: (0.95, 0.95, 1, 1)
                        on_release: app.update_friends()

                BoxLayout:
                    orientation: "vertical"
                    size_hint_x: 0.65
                    spacing: "12dp"
                    padding: "12dp"
                    canvas.before:
                        Color:
                            rgba: (0.05, 0.08, 0.17, 0.9)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [20]
                        Color:
                            rgba: (0.1, 0.14, 0.26, 0.8)
                        Line:
                            width: 1.2
                            rounded_rectangle: (self.x + 6, self.y + 6, self.width - 12, self.height - 12, 18)

                    BoxLayout:
                        orientation: "horizontal"
                        spacing: "10dp"
                        size_hint_y: None
                        height: "44dp"

                        TextInput:
                            id: request_target
                            hint_text: app.friend_hint_text
                            multiline: False
                            background_normal: ""
                            background_active: ""
                            background_color: (0.08, 0.1, 0.18, 1)
                            foreground_color: (1, 1, 1, 1)
                            padding: [14, 14, 14, 14]

                        Button:
                            text: app.request_button_text
                            size_hint_x: None
                            width: "160dp"
                            background_normal: ""
                            background_color: (0.08, 0.12, 0.2, 1)
                            color: (0.95, 0.95, 1, 1)
                            on_release: app.send_friend_request(request_target.text.strip())

                    Label:
                        text: app.messages_label
                        font_size: "18sp"
                        color: (0.9, 0.9, 1, 1)
                        bold: True
                        size_hint_y: None
                        height: "32dp"

                    ScrollView:
                        GridLayout:
                            id: pending_container
                            cols: 1
                            spacing: "8dp"
                            size_hint_y: None
                            height: self.minimum_height

                    TextInput:
                        id: message_input
                        hint_text: "Encrypted message"
                        size_hint_y: None
                        height: "120dp"
                        background_normal: ""
                        background_active: ""
                        background_color: (0.08, 0.1, 0.18, 1)
                        foreground_color: (1, 1, 1, 1)
                        padding: [14, 14, 14, 14]

                    BoxLayout:
                        size_hint_y: None
                        height: "44dp"
                        spacing: "10dp"

                        Button:
                            text: app.send_button_text
                            background_normal: ""
                            background_color: (0.08, 0.12, 0.2, 1)
                            color: (0.95, 0.95, 1, 1)
                            on_release:
                                app.send_message(message_input.text.strip())
                                message_input.text = ""

                        Button:
                            text: app.fetch_pending_text
                            background_normal: ""
                            background_color: (0.08, 0.12, 0.2, 1)
                            color: (0.95, 0.95, 1, 1)
                            on_release: app.update_pending()

                        Button:
                            text: app.ping_button_text
                            background_normal: ""
                            background_color: (0.08, 0.12, 0.2, 1)
                            color: (0.95, 0.95, 1, 1)
                            on_release: app.presence_ping()
